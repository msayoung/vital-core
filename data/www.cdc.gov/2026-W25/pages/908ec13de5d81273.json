: New York City Department of Health and Mental Hygiene (8), NYC Open Data (7). Data retrieved on April 7, 2021.","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":1000,"renderedHeight":638,"naturalWidth":1000,"naturalHeight":638,"loading":null,"decoding":"async","altVerdict":"TOO_LONG","altReason":"alt text is 561 characters — consider a caption or description","bytes":33253},{"src":"https://www.cdc.gov/images/arrow_up.gif","alt":"Return to your place in the text","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":58,"renderedHeight":34,"naturalWidth":58,"naturalHeight":34,"loading":null,"decoding":"async","altVerdict":"GOOD","altReason":"present, no red flags","bytes":1221},{"src":"https://www.cdc.gov/TemplatePackage/5.0/img/logo/cdc-logo-tag-right.svg","alt":"Centers for Disease Control and Prevention","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":283,"renderedHeight":66,"naturalWidth":827,"naturalHeight":193,"loading":null,"decoding":null,"altVerdict":"GOOD","altReason":"present, no red flags","bytes":4780},{"src":"https://www.cdc.gov/TemplatePackage/contrib/libs/cdc/c2r/crlogo.svg","alt":"Content Credentials logo","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":25,"renderedHeight":150,"naturalWidth":150,"naturalHeight":150,"loading":null,"decoding":null,"altVerdict":"GOOD","altReason":"present, no red flags","bytes":1490}]},"standards":{"engine":"standards","checks":[{"id":"schema-gov","label":"schema.org GovernmentOrganization markup","pass":false,"detail":""},{"id":"canonical","label":"Canonical URL declared","pass":true,"detail":""},{"id":"hreflang","label":"hreflang alternates declared","pass":false,"detail":""},{"id":"title","label":"Page has a <title>","pass":true,"detail":""},{"id":"descrip