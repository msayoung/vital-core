# Copy to .env (gitignored) for local use. In CI these are provided as
# repository secrets, NOT read from this file.

# Hugging Face write token with access to the target Space.
# Used by .github/workflows/deploy-huggingface.yml (as the HF_TOKEN secret).
HF_TOKEN=

# Optional: local or on-prem Ollama instance for AI summaries in ai-findings output.
# Leave unset to use http://localhost:11434 (the Ollama default).
VITAL_OLLAMA_URL=
# Optional: pin a specific model. Leave unset to use the first available model.
VITAL_OLLAMA_MODEL=
