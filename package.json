{
  "name": "vital-core",
  "version": "1.0.0",
  "description": "A quality scanner for websites built for the US government.",
  "main": "index.js",
  "scripts": {
    "validate": "npx tsx test-phase1.ts",
    "validate-phase2": "npx tsx test-phase2.ts",
    "validate-phase3": "npx tsx test-phase3.ts",
    "validate-phase4": "npx tsx test-phase4.ts",
    "validate-phase5": "npx tsx test-phase5.ts",
    "validate-phase6": "npx tsx test-phase6.ts",
    "build": "tsc",
    "validate:types": "tsc --noEmit",
    "validate:profile": "npx tsx test-phase1.ts",
    "validate:standards": "npm run validate-phase6",
    "test:phase": "npm run validate:profile && npm run validate:standards",
    "test:phase:live": "npm run validate-phase2 && npm run validate-phase3 && npm run validate-phase4 && npm run validate-phase5",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test": "npm run validate:types && npm run test:phase && npm run test:unit",
    "test:ci": "npm run validate:types && npm run test:phase && npm run test:unit:coverage",
    "submodules:init": "git submodule update --init --recursive",
    "submodules:update": "git submodule update --remote --merge --recursive",
    "history:fetch": "node scripts/fetch-history.mjs",
    "seeds:refresh": "npx tsx scripts/refresh-priority-seeds.ts",
    "inventory:export": "node scripts/export-target-inventory.mjs",
    "scan": "npx tsx src/index.ts profiles/us-health.yml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgifford/vital-core.git"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mgifford/vital-core/issues"
  },
  "homepage": "https://github.com/mgifford/vital-core#readme",
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "cheerio": "^1.2.0",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.3.0",
    "picomatch": "^4.0.4",
    "playwright": "^1.60.0",
    "sitemapper": "^4.1.6",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^25.9.1",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.7",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
